{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MyVPN",
  "mainBinaryName": "MyVPN",
  "version": "0.1.0",
  "identifier": "com.myvpn.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MyVPN",
        "label": "main",
        "width": 1040,
        "height": 720,
        "minWidth": 920,
        "minHeight": 640,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false,
        "theme": "Dark",
        "backgroundColor": "#0a0a0c"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["wintun.dll", "openvpn/*"],
    "shortDescription": "Your own serverless peer-to-peer VPN.",
    "longDescription": "MyVPN turns two Windows machines into your own private, end-to-end encrypted VPN with no middleware server. Host your network on one device and securely route all traffic from another.",
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"]
      }
    }
  }
}
